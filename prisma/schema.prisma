generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Material {
  id        String   @id @default(cuid())
  sku       String   @unique
  name      String
  unit      String
  quantity  Int      @default(0)
  minStock  Int      @default(0)
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  balances      InventoryBalance[]
  transactions  InventoryTransaction[]
  receivingLogs ReceivingRecord[]
}

model Job {
  id        String    @id @default(cuid())
  number    String    @unique
  name      String
  status    JobStatus @default(OPEN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  balances         InventoryBalance[]
  receivingLogs    ReceivingRecord[]
  expectedPos      ExpectedPurchaseOrder[]
  transactionsFrom InventoryTransaction[] @relation("TxFromJob")
  transactionsTo   InventoryTransaction[] @relation("TxToJob")
}

model InventoryBalance {
  id           String                @id @default(cuid())
  materialId   String
  locationType InventoryLocationType
  jobId        String?
  quantity     Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  job      Job?     @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([materialId, locationType, jobId])
  @@index([locationType, jobId])
}

model ReceivingRecord {
  id              String          @id @default(cuid())
  materialId      String
  quantity        Int
  destinationType DestinationType
  jobId           String?
  invoiceNumber   String?
  vendor          String?
  notes           String?
  photoUrl        String?
  receivedAt      DateTime
  createdAt       DateTime        @default(now())

  material     Material              @relation(fields: [materialId], references: [id])
  job          Job?                  @relation(fields: [jobId], references: [id], onDelete: SetNull)
  transaction  InventoryTransaction?
  poAlerts     PurchaseOrderAlert[]

  @@index([createdAt])
  @@index([materialId, receivedAt])
  @@index([jobId, receivedAt])
}

model InventoryTransaction {
  id                String                   @id @default(cuid())
  materialId        String
  transactionType   InventoryTransactionType
  quantity          Int
  locationFromType  InventoryLocationType?
  locationFromJobId String?
  locationToType    InventoryLocationType?
  locationToJobId   String?
  invoiceNumber     String?
  vendor            String?
  notes             String?
  photoUrl          String?
  receivingRecordId      String?                  @unique
  reversedTransactionId  String?                  @unique
  reversalReason         String?
  createdAt              DateTime                 @default(now())

  material              Material              @relation(fields: [materialId], references: [id])
  locationFromJob       Job?                  @relation("TxFromJob", fields: [locationFromJobId], references: [id], onDelete: SetNull)
  locationToJob         Job?                  @relation("TxToJob", fields: [locationToJobId], references: [id], onDelete: SetNull)
  receivingRecord       ReceivingRecord?      @relation(fields: [receivingRecordId], references: [id], onDelete: SetNull)
  reversedTransaction   InventoryTransaction? @relation("InventoryTransactionReversal", fields: [reversedTransactionId], references: [id], onDelete: SetNull)
  reversalTransaction   InventoryTransaction? @relation("InventoryTransactionReversal")

  @@index([materialId, createdAt])
  @@index([locationFromJobId, createdAt])
  @@index([locationToJobId, createdAt])
}


model ExpectedPurchaseOrder {
  id                 String   @id @default(cuid())
  poNumber           String
  normalizedPoNumber String   @unique
  ownerId            String?
  note               String?
  status             PurchaseOrderAlertStatus @default(OPEN)
  lastTriggeredAt    DateTime?
  seenAt             DateTime?
  resolvedAt         DateTime?
  triggerCount       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  jobId              String?

  job    Job?                  @relation(fields: [jobId], references: [id], onDelete: SetNull)
  owner  AdminUser?            @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  alerts PurchaseOrderAlert[]

  @@index([jobId])
  @@index([ownerId])
  @@index([poNumber])
}

model PurchaseOrderAlert {
  id                String   @id @default(cuid())
  expectedPoId      String
  receivingRecordId String
  ownerId           String?
  message           String
  status            PurchaseOrderAlertStatus @default(TRIGGERED)
  seenAt            DateTime?
  resolvedAt        DateTime?
  triggerCount      Int      @default(1)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  expectedPo      ExpectedPurchaseOrder @relation(fields: [expectedPoId], references: [id], onDelete: Cascade)
  owner           AdminUser?            @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  receivingRecord ReceivingRecord       @relation(fields: [receivingRecordId], references: [id], onDelete: Cascade)

  @@unique([expectedPoId, receivingRecordId])
  @@index([createdAt])
  @@index([ownerId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  expectedPurchaseOrders ExpectedPurchaseOrder[]
  purchaseOrderAlerts    PurchaseOrderAlert[]
}

enum InventoryTransactionType {
  RECEIVE
  TRANSFER
  ISSUE
  ADJUSTMENT
}

enum InventoryLocationType {
  SHOP
  JOB
}

enum JobStatus {
  OPEN
  CLOSED
}

enum DestinationType {
  SHOP
  JOB
}

enum PurchaseOrderAlertStatus {
  OPEN
  TRIGGERED
  SEEN
  RESOLVED
}
