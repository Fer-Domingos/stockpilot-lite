generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Material {
  id        String   @id @default(cuid())
  sku       String   @unique
  name      String
  unit      String
  quantity  Int      @default(0)
  minStock  Int      @default(0)
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions   InventoryTransaction[]
  receivingLogs  ReceivingRecord[]
  jobAllocations JobMaterialStock[]
}

model Job {
  id        String    @id @default(cuid())
  number    String    @unique
  name      String
  status    JobStatus @default(OPEN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  transactions   InventoryTransaction[]
  receivingLogs  ReceivingRecord[]
  materialStocks JobMaterialStock[]
}

model JobMaterialStock {
  id         String   @id @default(cuid())
  jobId      String
  materialId String
  quantity   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([jobId, materialId])
  @@index([materialId])
}

model ReceivingRecord {
  id                 String               @id @default(cuid())
  materialId         String
  quantity           Int
  destinationType    DestinationType
  jobId              String?
  invoiceNumber      String?
  vendorName         String?
  notes              String?
  photoUrl           String?
  receivedAt         DateTime
  createdAt          DateTime             @default(now())
  transaction        InventoryTransaction?

  material Material @relation(fields: [materialId], references: [id])
  job      Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([materialId, receivedAt])
  @@index([jobId, receivedAt])
}

model InventoryTransaction {
  id               String                   @id @default(cuid())
  materialId       String
  jobId            String?
  receivingRecordId String?                 @unique
  quantity         Int
  type             InventoryTransactionType
  locationFrom     String?
  locationTo       String?
  createdAt        DateTime                 @default(now())

  material        Material       @relation(fields: [materialId], references: [id])
  job             Job?           @relation(fields: [jobId], references: [id])
  receivingRecord ReceivingRecord? @relation(fields: [receivingRecordId], references: [id], onDelete: SetNull)

  @@index([materialId, createdAt])
  @@index([jobId, createdAt])
}

enum InventoryTransactionType {
  RECEIVE
  TRANSFER
}

enum JobStatus {
  OPEN
  CLOSED
}

enum DestinationType {
  SHOP
  JOB
}
