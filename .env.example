DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stockpilot_lite?schema=public"
AUTH_SECRET="replace-with-a-stable-long-random-secret"
# Optional during secret rotation so existing sessions survive the next deploy.
AUTH_SECRET_PREVIOUS=""
# Set to true only in the production environment that should run prisma migrate deploy.
RUN_PRISMA_MIGRATIONS="false"
